{% extends "layouts/main-logged.html" %}

{% block pageTitle %}
  Start page template – {{ serviceName }} – GOV.UK Prototype Kit
{% endblock %}

{% block beforeContent %}
  {{ super() }}
  {{ govukBackLink({
    text: "Back",
    href: "javascript:window.history.back()"
  }) }}
{% endblock %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {# {% from "govuk/components/radios/macro.njk" import govukRadios %} #}

      {{ govukCheckboxes({
        name: "animal-type",
        fieldset: {
          legend: {
            text: "Which species of poultry do you keep in this unit?",
            isPageHeading: true,
            classes: "govuk-fieldset__legend--l"
          }
        },
        hint: {
          text: "Select all species you keep in this unit"
        },
        items: [
          {
            value: "broilers",
            text: "Broilers"
          },
          {
            value: "hens",
            text: "Laying hens"
          },
          {
            value: "ducks",
            text: "Ducks"
          },
          {
            value: "geese",
            text: "Geese"
          },
          {
            value: "turkeys",
            text: "Turkeys"
          }
        ]
      }) }}

      <input type="hidden" name="nextPage" value="/new-user/check-your-answers">


            {{ govukButton({
              text: "Continue",
              href: "animals-number",
              isStartButton: false
            }) }}


    </div>

  </div>

{% endblock %}
