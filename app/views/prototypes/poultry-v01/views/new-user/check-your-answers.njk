{% extends "layouts/main-logged.html" %}

{% set animalType = data['animal-type'] or 'Laying hens' %}
{% set reviewDate = data['review-date'] or '4 September 2024' %}
{% set sampleDate = data['sample-date'] or '12 September 2024' %}
{% set animalsNumber = data['animals-number'] or 'Yes' %}
